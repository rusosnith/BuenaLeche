# =====================================================
# LABVIMA SYNC — Configuración Google Sheets
# =====================================================

# Credenciales del portal LABVIMA
LABVIMA_USUARIO=TU_USUARIO_AQUI
LABVIMA_CLAVE=TU_CLAVE_AQUI

# URL de tu Google Sheet (la URL completa que ves en el navegador)
# Ejemplo: https://docs.google.com/spreadsheets/d/1ABC.../edit
SHEET_URL=https://docs.google.com/spreadsheets/d/TU_ID_AQUI/edit

# Nombre exacto de la hoja dentro del Sheet (la pestaña)
SHEET_NOMBRE=Registro_Calidad

# Ruta al archivo JSON de credenciales de Google (cuenta de servicio)
# Ponerlo en esta misma carpeta y escribir solo el nombre del archivo
GOOGLE_CREDENTIALS_JSON=credenciales_google.json

# Carpeta donde se guardan los PDFs descargados
PDF_FOLDER=./pdfs_labvima
